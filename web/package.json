{
  "name": "highest-bid",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "db:create": "wrangler d1 create highest-bid-db",
    "db:migrate:local": "wrangler d1 execute highest-bid-db --local --file=./migrations/001_init.sql && wrangler d1 execute highest-bid-db --local --file=./migrations/002_multiplayer.sql",
    "db:migrate:remote": "wrangler d1 execute highest-bid-db --file=./migrations/001_init.sql && wrangler d1 execute highest-bid-db --file=./migrations/002_multiplayer.sql",
    "db:migrate2:local": "wrangler d1 execute highest-bid-db --local --file=./migrations/002_multiplayer.sql",
    "db:migrate2:remote": "wrangler d1 execute highest-bid-db --file=./migrations/002_multiplayer.sql"
  },
  "dependencies": {
    "@tanstack/react-router": "^1.170.16",
    "@tanstack/react-start": "^1.168.26",
    "drizzle-orm": "^0.45.2",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.42.4",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.3",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.6.0",
    "vite": "^8.1.2",
    "wrangler": "^4.106.0"
  }
}
